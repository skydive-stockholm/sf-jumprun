{
    "name": "sf-jumprun",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite --port 3000",
        "build": "vite build",
        "preview": "vite preview",
        "format": "prettier .  --write",
        "lint": "eslint --ext .js,.vue --ignore-path .gitignore --fix src",
        "admin": "node backend/admin.js",
        "backend": "nodemon backend/backend.js"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "lint-staged": {
        "*.{js,jsx}": [
            "prettier --write",
            "eslint --fix",
            "git add"
        ],
        "*.{html,css,less,ejs}": [
            "prettier --write",
            "git add"
        ]
    },
    "dependencies": {
        "@heroicons/vue": "^2.0.18",
        "@turf/circle": "^6.5.0",
        "@turf/turf": "^6.5.0",
        "axios": "^1.4.0",
        "lodash": "^4.17.21",
        "mapbox-gl": "^2.15.0",
        "vue": "^3.2.47",
        "vue-router": "4"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^4.1.0",
        "eslint": "^8.44.0",
        "eslint-config-prettier": "^8.8.0",
        "eslint-plugin-vue": "^9.15.1",
        "husky": "^8.0.3",
        "lint-staged": "^13.2.3",
        "prettier": "^3.0.0",
        "vite": "^4.3.9",
        "vite-plugin-eslint": "^1.8.1"
    }
}
