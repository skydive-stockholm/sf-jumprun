{
    "name": "sf-jumprun",
    "version": "1.0.0",
    "description": "Jump run visualization for Skydive Stockholm",
    "author": "Skydive Stockholm",
    "main": "electron/main.cjs",
    "type": "module",
    "scripts": {
        "dev": "vite --port 3000",
        "build": "vite build",
        "preview": "vite preview",
        "format": "prettier .  --write",
        "lint": "eslint --ext .js,.vue --ignore-path .gitignore --fix src",
        "backend": "nodemon backend/standalone.js --ignore 'data.json'",
        "test": "vitest run",
        "test:watch": "vitest",
        "electron:dev": "concurrently \"npm run dev\" \"wait-on tcp:3000 && electron .\"",
        "electron:build": "npm run build && electron-builder",
        "electron:build:win": "npm run build && electron-builder --win",
        "electron:build:mac": "npm run build && electron-builder --mac"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "lint-staged": {
        "*.{js,jsx}": [
            "prettier --write",
            "eslint --fix",
            "git add"
        ],
        "*.{html,css,less,ejs}": [
            "prettier --write",
            "git add"
        ]
    },
    "dependencies": {
        "@heroicons/vue": "^2.0.18",
        "@serialport/parser-readline": "^11.0.0",
        "@turf/circle": "^6.5.0",
        "@turf/turf": "^6.5.0",
        "cheerio": "^1.0.0-rc.12",
        "dotenv": "^16.3.1",
        "electron-updater": "^6.8.3",
        "express": "^4.18.2",
        "leaflet": "^1.9.4",
        "nodemon": "^3.1.14",
        "serialport": "^11.0.0",
        "vue": "^3.2.47",
        "vue-router": "4"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^4.1.0",
        "@vue/test-utils": "^2.4.6",
        "concurrently": "^9.2.1",
        "electron": "^40.8.0",
        "electron-builder": "^26.8.1",
        "eslint": "^8.44.0",
        "eslint-config-prettier": "^8.8.0",
        "eslint-plugin-vue": "^9.15.1",
        "husky": "^8.0.3",
        "jsdom": "^28.1.0",
        "lint-staged": "^13.2.3",
        "prettier": "^3.0.0",
        "vite": "^4.3.9",
        "vite-plugin-eslint": "^1.8.1",
        "vitest": "^4.0.18",
        "wait-on": "^9.0.4"
    }
}
